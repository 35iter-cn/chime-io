{
  "name": "@chime-io/plugin-opencode",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@chime-io/core": "workspace:*",
