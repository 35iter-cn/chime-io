{
  "name": "@chime-io/cli",
  "version": "1.1.0",
  "description": "CLI tool for Claude Code notifications and Telegram alerts - developer notification tool for AI coding workflows",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "bin": {
    "chime": "./dist/index.cjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.cts",
      "default": "./dist/index.cjs"
    }
  },
  "keywords": [
    "claude-code",
    "telegram",
    "notification",
    "ai-coding",
    "developer-tools",
    "mobile-notification",
    "cli",
    "automation",
    "ci-cd",
    "alert"
  ],
  "homepage": "https://github.com/yourusername/telnotify#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/telnotify.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/yourusername/telnotify/issues"
  },
  "author": "Chime IO Team",
  "license": "MIT",
  "dependencies": {
    "@chime-io/core": "workspace:*",
    "@chime-io/channel-telegram": "workspace:*"
  },
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "tsx --test src/test/**/*.test.ts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit --pretty false"
  },
  "devDependencies": {
    "@types/node": "~25.5.2",
    "tsup": "~8.4.0",
    "tsx": "~4.21.0",
    "typescript": "^5.8.3"
  }
}
