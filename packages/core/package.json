{
  "name": "@chime-io/core",
  "version": "1.1.0",
  "description": "Core library for Chime IO - notification models, renderers, and utilities for AI coding notifications",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "types": "./dist/index.d.cts",
      "default": "./dist/index.cjs"
    }
  },
  "keywords": [
    "notification",
    "core",
    "models",
    "ai-coding",
    "developer-tools",
    "claude-code",
    "telegram",
    "typescript"
  ],
  "homepage": "https://github.com/yourusername/telnotify#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/telnotify.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/yourusername/telnotify/issues"
  },
  "author": "Chime IO Team",
  "license": "MIT",
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "tsx --test src/test/**/*.test.ts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit --pretty false"
  },
  "devDependencies": {
    "@types/node": "~25.5.2",
    "tsup": "~8.4.0",
    "tsx": "~4.21.0",
    "typescript": "^5.8.3"
  }
}
