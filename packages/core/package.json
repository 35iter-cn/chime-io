{
  "name": "@chime-io/core",
  "version": "1.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "types": "./dist/index.d.cts",
      "default": "./dist/index.cjs"
    }
  },
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "tsx --test src/test/**/*.test.ts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit --pretty false"
  },
  "devDependencies": {
    "@types/node": "~25.5.2",
    "tsup": "~8.4.0",
    "tsx": "~4.21.0",
    "typescript": "^5.8.3"
  }
}
