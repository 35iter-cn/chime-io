{
  "name": "@chime-io/core",
  "version": "1.0.2",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsc -b",
    "build:watch": "tsc -b --watch --preserveWatchOutput",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc -b --pretty false"
  }
}
