{
  "name": "telnotify-workspace",
  "private": true,
  "packageManager": "pnpm@10.6.0",
  "scripts": {
    "build": "node common/scripts/install-run-rush.js build",
    "build:watch": "pnpm -r run build:watch",
    "clean": "pnpm -r run clean",
    "release:dry-run": "node common/scripts/install-run-rush.js publish --include-all --version-policy individual --pack",
    "test": "node common/scripts/install-run-rush.js build && node common/scripts/install-run.js tsx@4.19.3 tsx --test packages/*/test/*.test.ts apps/*/test/*.test.ts",
    "typecheck": "pnpm -r run typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "tsx": "^4.19.3",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3"
  }
}
