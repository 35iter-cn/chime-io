{
  "name": "@chime-io/cli",
  "version": "1.0.3",
  "type": "module",
  "bin": {
    "chime": "./dist/index.js"
  },
  "publishConfig": { "access": "public" },
  "dependencies": {
    "@chime-io/core": "workspace:*",
    "@chime-io/channel-telegram": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "typescript": "^5.8.3"
  },
  "scripts": {
    "build": "tsc -b",
    "build:watch": "tsc -b --watch --preserveWatchOutput",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc -b --pretty false"
  }
}
