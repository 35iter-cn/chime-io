{
  "name": "@chime-io/cli",
  "version": "1.0.4",
  "type": "module",
  "bin": {
    "chime": "./dist/index.js"
  },
  "publishConfig": { "access": "public" },
  "dependencies": {
    "@chime-io/core": "workspace:*",
    "@chime-io/channel-telegram": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "~25.5.2",
    "typescript": "^6.0.2",
    "tsx": "~4.21.0"
  },
  "scripts": {
    "build": "tsc -b",
    "build:watch": "tsc -b --watch --preserveWatchOutput",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "typecheck": "tsc -b --pretty false"
  }
}
